# Splunk MCP Streamable HTTP endpoint.
SPLUNK_MCP_URL=https://splunk-mcp.example.com/mcp
SPLUNK_MCP_AUTH_TOKEN=replace-with-mcp-bearer-token
SPLUNK_MCP_PROTOCOL_VERSION=2025-11-25
SPLUNK_MCP_TIMEOUT_MS=30000
SPLUNK_MCP_CLIENT_NAME=release-preflight
SPLUNK_MCP_CLIENT_VERSION=0.1.0

# Splunk HTTP Event Collector event endpoint or Splunk HEC host.
SPLUNK_HEC_URL=https://http-inputs-example.splunkcloud.com/services/collector/event
SPLUNK_HEC_TOKEN=replace-with-hec-token
SPLUNK_HEC_TIMEOUT_MS=30000
SPLUNK_HEC_ALLOW_SELF_SIGNED=false
SPLUNK_HEC_INDEX=main
SPLUNK_HEC_SOURCE=release-preflight
SPLUNK_HEC_SOURCETYPE=release_preflight:deployment
SPLUNK_HEC_HOST=
SPLUNK_HEC_CHANNEL=

# Optional narrative tool exposed through Splunk MCP.
SPLUNK_MCP_AI_TOOL=saia_ask_splunk_question
RELEASE_PREFLIGHT_REQUIRE_AI=false
